<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

        <!-- Chassis Variables (all in metric) -->
    <xacro:property name="box_length" value="0.7"/> <!--meters-->
    <xacro:property name="box_width" value="0.35"/>
    <xacro:property name="box_height" value="0.15"/>
    <xacro:property name="box_mass" value="10"/>

    <xacro:property name="wheel_width" value="0.075"/>
    <xacro:property name="wheel_radius" value="0.127"/>
    <xacro:property name="wheel_offset" value="${box_width/2 + wheel_width/2}"/>
    <xacro:property name="wheel_mass" value="1.0"/> <!--kg-->
    <xacro:property name="wheel_torque" value="50"/> <!--N.m-->
    <xacro:property name="wheel_speed" value="10.0"/> <!--rad/s-->

    <xacro:property name="caster_radius" value="0.0635"/>
    <xacro:property name="caster_Xoffset" value="${box_length - caster_radius}"/>
    <xacro:property name="caster_Yoffset" value="${box_width/2 - caster_radius}"/>
    <xacro:property name="caster_Zoffset" value="${-wheel_radius + caster_radius}"/>
    <xacro:property name="caster_mass" value="0.5"/>

    <xacro:include filename="inertial_macros.xacro" />


    <!--BASE LINK-->
    <link name="base_link">
    </link>

        <!-- BASE_FOOTPRINT -->
        <!--The base location in flat 2D since the robot will be changing elevation-->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 -${wheel_radius}" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>

    <!-- Chassis -->

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="-${wheel_radius} 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="${box_length / 2.0} 0 ${box_height / 2.0}" rpy="0 0 0"/>
            <geometry>
                <box size="${box_length} ${box_width} ${box_height}"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
             <origin xyz="${box_length / 2.0} 0 ${box_height / 2.0}" rpy="0 0 0"/>
            <geometry>
                <box size="${box_length} ${box_width} ${box_height}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="${box_mass}" x="${box_length}" y="${box_width}" z="${box_height}">
            <origin xyz="${box_length / 2.0} 0 ${box_height / 2.0}" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- LEFT WHEEL -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 ${wheel_offset} 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="${wheel_torque}" velocity="${wheel_speed}"/>

    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder length="${wheel_width}" radius="${wheel_radius}" />
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}" /> <!--Sphere for friction/simulation purposes-->
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_width}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <!--Fricition parameters-->
        <mu1 value="0.7"/>
        <mu2 value="0.7"/>
    </gazebo>

    <!-- RIGHT WHEEL -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -${wheel_offset} 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
        <limit effort="${wheel_torque}" velocity="${wheel_speed}"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder length="${wheel_width}" radius="${wheel_radius}" />
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}" /> <!--Sphere for friction/simulation purposes-->
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_width}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <!--Fricition parameters-->
        <mu1 value="0.7"/>
        <mu2 value="0.7"/>
    </gazebo>

    <!-- LEFT CASTER WHEEL -->

    <joint name="left_caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="left_caster_wheel"/>
        <origin xyz="${caster_Xoffset} ${caster_Yoffset} ${caster_Zoffset}" rpy="0 0 0"/>
    </joint>

    <link name="left_caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${caster_radius}" />
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${caster_radius}" />
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="${caster_mass}" radius="${caster_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="left_caster_wheel">
        <!--Friction parameters-->
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

       <!-- RIGHT CASTER WHEEL -->

    <joint name="right_caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="right_caster_wheel"/>
        <origin xyz="${caster_Xoffset} ${-caster_Yoffset} ${caster_Zoffset}" rpy="0 0 0"/>
    </joint>

    <link name="right_caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${caster_radius}" />
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${caster_radius}" />
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="${caster_mass}" radius="${caster_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="right_caster_wheel">
        <!--Fricition parameters-->
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

        <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

</robot>